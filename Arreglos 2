
#include <stdio.h>
#include <stdlib.h>

int main() {
    int N;
    float temp[N];
    int i;

    for (i = 0; i < N; i++) {
        printf("Ingrese la temperatura %d: ", i+1);
        scanf("%f", &temp[i]);
    }

    for (i = 0; i < N; i++) {
        printf("Temperatura %d: %.2f\n", i+1, temp[i]);
    }

    return 0;
}
